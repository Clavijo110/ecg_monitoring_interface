{
  "buildCommand": "echo 'Frontend only'",
  "outputDirectory": "public",
  "installCommand": "npm install --no-save",
  "headers": [
    {
      "source": "(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path((?!api).*)*",
      "destination": "/"
    }
  ]
}

